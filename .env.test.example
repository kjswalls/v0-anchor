# Copy this file to .env.test and fill in real test credentials.
# NEVER commit .env.test — it is git-ignored.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=your-test-password-here

# NOTE: E2E API helpers (createTestTask, createTestHabit) authenticate via
# the test user's OpenClaw API key, which is fetched automatically at runtime
# via GET /api/agent/apikey using the test user's session cookies. The test
# user must have generated an API key at least once (Settings → AI → API Key).
# No separate env var is required.
